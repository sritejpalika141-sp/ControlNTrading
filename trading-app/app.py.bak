# Multi-User Session Cache & State Map
USER_CONTEXTS = {}
USER_STATES = {}

def get_user_state(user_id) -> TradingState:
    """Get or create TradingState for a user. Always normalizes user_id to int."""
    u_id = int(user_id)
    if u_id not in USER_STATES:
        USER_STATES[u_id] = TradingState(user_id=u_id)
    return USER_STATES[u_id]

def get_lot_size(symbol: str) -> int:
    """Get the official NSE lot size (effective Jan 2026)."""
    symbol_upper = symbol.upper()
    if "BANKNIFTY" in symbol_upper:
        return 30
    if "FINNIFTY" in symbol_upper:
        return 60
    if "MIDCPNIFTY" in symbol_upper:
        return 120
    if "NIFTY" in symbol_upper:
        return 65
    return 65  # Default fallback

# --- AUTHENTICATION ROUTES (v4.2.0) ---
@app.get("/login")
async def login_page():
    return FileResponse(BASE_DIR / "static" / "login.html")

@app.post("/api/login")
async def login_api(request: Request):
    try:
        data = await request.json()
        username = data.get("username", "").strip()
        password = data.get("password", "").strip()
        print(f"🔐 Login attempt for: '{username}' with password length: {len(password)}")
        
        user = await asyncio.to_thread(Database.get_user_by_username, username)
        if user:
            print(f"✅ User found in DB. Verifying password...")
            if Database.verify_password(password, user["password_hash"]):
                print("✅ Password matches!")
                response = JSONResponse({"success": True})
                response.set_cookie(key="user_id", value=str(user["id"]), max_age=86400 * 30, path="/", httponly=True, samesite="lax")
                response.set_cookie(key="username", value=user["username"], max_age=86400 * 30, path="/", samesite="lax")
                return response
            else:
                print("❌ Password did not match!")
        else:
            print("❌ User not found!")
            
        return JSONResponse({"success": False, "message": "Invalid credentials"})
    except Exception as e:
        print(f"💥 Login API Exception: {e}")
        return JSONResponse({"success": False, "message": str(e)})

@app.get("/logout")
async def logout(request: Request):
    reason = request.query_params.get("reason")
    url = "/login"
    if reason:
        url += f"?reason={reason}"
    response = RedirectResponse(url=url)
    response.delete_cookie("user_id", path="/")
    response.delete_cookie("username", path="/")
    return response

# Protected main route
@app.get("/")
async def root(request: Request):
    user_id = request.cookies.get("user_id")
    auth_code = request.query_params.get("auth_code")
    
    print(f"🏠 Root route: user_id cookie = '{user_id}', auth_code = '{bool(auth_code)}'", flush=True)
    
    if auth_code and user_id:
        try:
            user = await asyncio.to_thread(Database.get_user_by_id, user_id)
            if user:
                from fyers_apiv3 import fyersModel
                client_id = user.get("fyers_client_id")
                secret_key = user.get("fyers_secret")
                if client_id and secret_key:
                    session = fyersModel.SessionModel(
                        client_id=client_id,
                        secret_key=secret_key,
                        redirect_uri=os.getenv("FYERS_REDIRECT_URI", "https://trade.fyers.in/api-login/redirect-uri/index.html"),
                        response_type='code',
                        grant_type='authorization_code'
                    )
                    session.set_token(auth_code)
                    token_resp = session.generate_token()
                    if "access_token" in token_resp:
                        token = token_resp["access_token"]
                        await asyncio.to_thread(Database.update_fyers_token, user_id, token)
                        u_id_int = int(user_id)
                        if u_id_int in USER_CONTEXTS:
                            del USER_CONTEXTS[u_id_int]
                        return RedirectResponse(url="/?msg=Connected")
                    else:
                        print(f"⚠️ Fyers token exchange failed: {token_resp}", flush=True)
                else:
                    print(f"⚠️ User {user_id} missing fyers_client_id or fyers_secret", flush=True)
        except Exception as e:
            print(f"❌ Auth code exchange error: {e}", flush=True)

    if not user_id:
        print("🏠 → Serving landing.html (no user_id cookie)", flush=True)
        response = FileResponse(BASE_DIR / "static" / "landing.html")
        response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate"
        return response
    
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user:
        print(f"🏠 → Serving landing.html (user_id={user_id} not found in DB)", flush=True)
        response = FileResponse(BASE_DIR / "static" / "landing.html")
        response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate"
        response.delete_cookie("user_id", path="/")
        response.delete_cookie("username", path="/")
        return response
    
    print(f"🏠 → Serving index.html for user '{user.get('username', '?')}' (id={user_id})", flush=True)
    response = FileResponse(BASE_DIR / "static" / "index.html")
    response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate"
    return response

# --- ADMIN ROUTES (v4.2.0) ---
@app.get("/admin")
async def admin_page(request: Request):
    user_id = request.cookies.get("user_id")
    if not user_id: return RedirectResponse(url="/login")
    
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user or not user["is_admin"]:
        return "Unauthorized: Admins only"
    return FileResponse(BASE_DIR / "static" / "admin.html")

@app.get("/api/admin/users")
async def admin_get_users(request: Request):
    user_id = request.cookies.get("user_id")
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user or not user["is_admin"]: return JSONResponse({"error": "Unauthorized"}, 403)
    
    conn = sqlite3.connect(Database.DB_NAME)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    c.execute("SELECT id, username, is_admin, automation_enabled, created_at FROM users")
    users = [dict(u) for u in c.fetchall()]
    conn.close()
    return users

@app.post("/api/admin/users")
async def admin_add_user(request: Request):
    user_id = request.cookies.get("user_id")
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user or not user["is_admin"]: return JSONResponse({"error": "Unauthorized"}, 403)
    
    data = await request.json()
    new_id = await asyncio.to_thread(Database.create_user, 
        data.get("username"), 
        data.get("password"), 
        is_admin=data.get("is_admin", 0)
    )
    if new_id: return {"success": True, "id": new_id}
    return {"success": False, "message": "User already exists"}

@app.delete("/api/admin/users/{id}")
async def admin_delete_user(id: int, request: Request):
    user_id = request.cookies.get("user_id")
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user or not user["is_admin"]: return JSONResponse({"error": "Unauthorized"}, 403)
    
    conn = sqlite3.connect(Database.DB_NAME)
    c = conn.cursor()
    c.execute("DELETE FROM users WHERE id=?", (id,))
    c.execute("DELETE FROM user_states WHERE user_id=?", (id,))
    conn.commit()
    conn.close()
    return {"success": True}

@app.post("/api/admin/users/{id}/password")
async def admin_change_password(id: int, request: Request):
    user_id = request.cookies.get("user_id")
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user or not user["is_admin"]: return JSONResponse({"error": "Unauthorized"}, 403)
    
    data = await request.json()
    new_password = data.get("new_password")
    if not new_password or len(new_password) < 6:
        return {"success": False, "message": "Password must be at least 6 characters"}
        
    await asyncio.to_thread(Database.update_password, id, new_password)
    return {"success": True, "message": "Password updated successfully"}

@app.get("/api/fyers/login_url")
async def get_fyers_login_url(request: Request):
    user_id = request.cookies.get("user_id")
    user = await asyncio.to_thread(Database.get_user_by_id, user_id)
    if not user: return JSONResponse({"error": "Unauthorized"}, 401)
    
    client_id = user.get("fyers_client_id")
    secret = user.get("fyers_secret")
    if not client_id or not secret: return JSONResponse({"error": "Missing API IDs"}, 400)
    
    from fyers_apiv3 import fyersModel
    redirect_url = os.getenv("FYERS_REDIRECT_URI", "https://trade.fyers.in/api-login/redirect-uri/index.html")
    session = fyersModel.SessionModel(
        client_id=client_id,
        secret_key=secret,
        redirect_uri=redirect_url,
        response_type='code',
        grant_type='authorization_code'
    )
    return {"url": session.generate_authcode()}

@app.post("/api/user/settings")
async def save_settings(request: Request):
    user_id = request.cookies.get("user_id")
    if not user_id:
        return JSONResponse({"success": False, "message": "Unauthorized"}, 401)
    
    data = await request.json()
    client_id = data.get("client_id")
    secret_id = data.get("secret_id")
    
    await asyncio.to_thread(Database.update_fyers_creds, user_id, client_id, secret_id)
    
    # Refresh context
    try:
        u_id_int = int(user_id)
        if u_id_int in USER_CONTEXTS:
            del USER_CONTEXTS[u_id_int]
    except Exception as e:
        print(f"Error clearing user context: {e}")
        
    return {"success": True}

