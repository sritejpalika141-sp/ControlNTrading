    return {"success": True, "config": {"theme": "dark", "notifications": True}}

@app.get("/api/pnl-history")
async def get_pnl_history(request: Request):
    try:
        client = get_current_client(request)
        if not client or not client.user_id:
            return {"success": False, "message": "Not authenticated"}
        
        # Query history from Database
        from models import Database
        history = Database.get_pnl_history(int(client.user_id), months_limit=6)
        
        # Get active live state for today's running PnL
        state = get_user_state(client.user_id)
        state.check_daily_reset()
        
        today_str = state.last_reset_date
        history_dates = {item["date"] for item in history}
        
        if today_str not in history_dates:
            history.insert(0, {
                "date": today_str,
                "pnl": state.pnl_today,
                "trades": state.trades_today,
                "active": True
            })
        else:
            for item in history:
                if item["date"] == today_str:
                    item["active"] = True
                    item["pnl"] = state.pnl_today
                    item["trades"] = state.trades_today
                    break
                    
        return {"success": True, "history": history}
    except Exception as e:
        logger.error(f"❌ Error getting PnL history: {e}", exc_info=True)
        return {"success": False, "message": str(e)}

@app.get("/api/health")
async def health_check():
    """Production health check — returns uptime, active users, memory, task status."""
    import resource
    ist = pytz.timezone('Asia/Kolkata')
    now = datetime.now(ist)
    uptime_delta = now - SERVER_START_TIME
    hours, remainder = divmod(int(uptime_delta.total_seconds()), 3600)
    minutes, seconds = divmod(remainder, 60)
    
    # Memory usage (RSS in MB)
    mem_mb = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss / (1024 * 1024)
    
    # Active user count
    active_users = len(USER_CONTEXTS)
    ws_connections = len(active_connections)
    
    # Auth status per user
    user_auth = {}
    for u_id in USER_CONTEXTS:
        cache = get_user_cache(u_id)
        user_auth[str(u_id)] = cache.get("is_auth", False)
    
    return {
        "status": "healthy",
        "version": VERSION,
        "uptime": f"{hours}h {minutes}m {seconds}s",
        "started_at": SERVER_START_TIME.strftime("%Y-%m-%d %H:%M:%S IST"),
        "memory_mb": round(mem_mb, 1),
        "active_users": active_users,
        "ws_connections": ws_connections,
        "user_auth": user_auth,
        "market_open": _is_market_open(),
        "timestamp": now.isoformat()
    }

# ══════════════════════════════════════════════════════
# NSE INDIA MARKET DATA PROXY — Server-side fetch
# (avoids CORS issues from browser-direct calls)
# ══════════════════════════════════════════════════════
import urllib.request
import xml.etree.ElementTree as ET

_NSE_CACHE = {"indices": None, "news": None, "last_indices": None, "last_news": None}
_NSE_CACHE_TTL = 60  # seconds

_NSE_HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
    "Accept": "*/*",
    "Accept-Language": "en-US,en;q=0.9",
    "Referer": "https://www.nseindia.com/",
    "Connection": "keep-alive",
}

def _nse_get(url: str, cookies: str = "") -> dict:
    req = urllib.request.Request(url)
    for k, v in _NSE_HEADERS.items():
        req.add_header(k, v)
    if cookies:
        req.add_header("Cookie", cookies)
    with urllib.request.urlopen(req, timeout=12) as resp:
        return json.loads(resp.read().decode("utf-8"))

def _rss_get(url: str) -> list:
    req = urllib.request.Request(url)
    req.add_header("User-Agent", _NSE_HEADERS["User-Agent"])
    with urllib.request.urlopen(req, timeout=12) as resp:
        raw = resp.read()
    root = ET.fromstring(raw)
    items = []
    for item in root.findall(".//item")[:10]:
        title = item.findtext("title", "").strip()
        pub   = item.findtext("pubDate", "").strip()
        link  = item.findtext("link", "").strip()
        if title:
            items.append({"title": title, "pubDate": pub, "link": link})
    return items

def _get_nse_cookies() -> str:
    """Hit NSE home to get session cookies."""
    try:
        req = urllib.request.Request("https://www.nseindia.com/")
        for k, v in _NSE_HEADERS.items():
            req.add_header(k, v)
        with urllib.request.urlopen(req, timeout=12) as resp:
            raw_cookies = resp.getheader("Set-Cookie") or ""
            # Extract key=value pairs
            parts = [p.strip().split(";")[0] for p in raw_cookies.split(",") if "=" in p.split(";")[0]]
            return "; ".join(parts)
    except Exception:
        return ""

@app.get("/api/market-data")
async def get_market_data():
    """Proxy endpoint: fetches live index prices from NSE India."""
    now = datetime.now(IST)
    last = _NSE_CACHE.get("last_indices")
    if _NSE_CACHE["indices"] and last and (now - last).total_seconds() < _NSE_CACHE_TTL:
        return JSONResponse(content=_NSE_CACHE["indices"])

    try:
        cookies = await asyncio.get_event_loop().run_in_executor(None, _get_nse_cookies)
        raw = await asyncio.get_event_loop().run_in_executor(
            None, lambda: _nse_get("https://www.nseindia.com/api/allIndices", cookies)
        )
        # Filter to indices we care about
        wanted = {"NIFTY 50", "NIFTY BANK", "NIFTY MIDCAP 50", "NIFTY NEXT 50",
                  "NIFTY IT", "NIFTY AUTO", "NIFTY FMCG", "NIFTY PHARMA",
                  "INDIA VIX", "NIFTY FINANCIAL SERVICES"}
        filtered = [
            {
                "name": d.get("index", d.get("indexSymbol", "")),
                "last": d.get("last", 0),
                "change": round(d.get("variation", 0), 2),
                "pct": round(d.get("percentChange", 0), 2),
                "open": d.get("open", 0),
                "high": d.get("high", 0),
                "low":  d.get("low", 0),
                "prev": d.get("previousClose", 0),
            }
            for d in raw.get("data", [])
            if d.get("index") in wanted or d.get("indexSymbol") in wanted
        ]
        # Add market status
        market_status = raw.get("marketStatus", {})
        result = {"indices": filtered, "market": market_status, "source": "NSE India", "fetched_at": now.strftime("%H:%M:%S IST")}
        _NSE_CACHE["indices"] = result
        _NSE_CACHE["last_indices"] = now
        return JSONResponse(content=result)
    except Exception as e:
        print(f"[NSE] Market data fetch failed: {e}")
        if _NSE_CACHE["indices"]:
            cached = dict(_NSE_CACHE["indices"])
            cached["cached"] = True
            return JSONResponse(content=cached)
        return JSONResponse(content={"error": str(e), "indices": []}, status_code=503)


@app.get("/api/market-news")
async def get_market_news():
    """Proxy endpoint: fetches latest Indian market news from Economic Times RSS."""
    now = datetime.now(IST)
    last = _NSE_CACHE.get("last_news")
    if _NSE_CACHE["news"] and last and (now - last).total_seconds() < 300:  # 5-min cache
        return JSONResponse(content=_NSE_CACHE["news"])

    feeds = [
        {"url": "https://economictimes.indiatimes.com/markets/rss.cms", "source": "Economic Times"},
        {"url": "https://www.moneycontrol.com/rss/MCtopnews.xml",        "source": "Moneycontrol"},
    ]
    all_news = []
    for feed in feeds:
        try:
            items = await asyncio.get_event_loop().run_in_executor(None, lambda u=feed["url"]: _rss_get(u))
            for item in items[:5]:
                item["source"] = feed["source"]
                all_news.append(item)
        except Exception as ex:
            print(f"[NEWS] RSS fetch failed for {feed['source']}: {ex}")

    result = {"news": all_news[:12], "fetched_at": now.strftime("%H:%M:%S IST")}
    if all_news:
        _NSE_CACHE["news"] = result
        _NSE_CACHE["last_news"] = now
    return JSONResponse(content=result)


@app.get("/api/version")
async def get_version(request: Request):
    """Return dashboard version and system info."""
    client = get_current_client(request)
    state = get_user_state(client.user_id)
    ist = pytz.timezone('Asia/Kolkata')
    now = datetime.now(ist)
    uptime_delta = now - SERVER_START_TIME
    hours, remainder = divmod(int(uptime_delta.total_seconds()), 3600)
    minutes, seconds = divmod(remainder, 60)
    return {
        "version": VERSION,
        "name": "ControlN Trading Dashboard",
        "active_symbols": len(state.active_symbols),
        "automation": state.automation_enabled,
        "ai_active": ai_engine.enabled or ai_engine.openai_enabled,
        "ai_provider": "Both" if (ai_engine.enabled and ai_engine.openai_enabled) else "Gemini" if ai_engine.enabled else "ChatGPT" if ai_engine.openai_enabled else "None",
        "uptime": f"{hours}h {minutes}m {seconds}s",
        "started_at": SERVER_START_TIME.strftime("%H:%M:%S IST")
    }

async def trailing_monitor():
    """Background task to monitor active auto-trades, trail SL, and enforce max loss limit."""
    
    while True:
        try:
            for u_id, client in USER_CONTEXTS.items():
                state = get_user_state(u_id)
                MAX_LOSS_LIMIT = -abs(state.max_loss_per_day)
                
                if not state.active_auto_trades:
                    continue
                    
                try:
                    if not await asyncio.to_thread(client.is_authenticated):
                        continue
                except:
                    continue
                    
                # ═══════════════════════════════════════════
                # MAX LOSS CHECK — Emergency Exit
                # ═══════════════════════════════════════════
                cache = get_user_cache(u_id)
                positions = cache.get("active_positions", [])
                has_open = any(p.get("netQty", 0) != 0 or p.get("qty", 0) != 0 for p in positions)
                if not has_open and state.trades_today == 0:
                    total_pnl = 0.0
                else:
                    total_pnl = sum(p.get("pl", 0) for p in positions) if positions else 0
                
                # Update state PnL
                state.update_pnl(total_pnl)
                
                if total_pnl <= MAX_LOSS_LIMIT:
                    logger.warning(f"🚨 MAX LOSS BREACHED! PnL: ₹{total_pnl:.2f} <= ₹{MAX_LOSS_LIMIT}")
                    await broadcast_log(f"🚨 EMERGENCY EXIT: Loss ₹{abs(total_pnl):.0f} exceeded ₹{abs(MAX_LOSS_LIMIT):.0f} limit!", "error")
                
                    # Square off ALL open positions
                    open_positions = [p for p in positions if p.get("qty", 0) != 0]
                    for pos in open_positions:
                        try:
                            qty = abs(pos.get("qty", 0))
                            symbol = pos.get("symbol", "")
                            side = "SELL" if pos.get("side", 1) > 0 else "BUY"
                            
                            logger.info(f"🔴 Emergency exit: {side} {qty} x {symbol}")
                            await broadcast_log(f"🔴 Exiting: {side} {qty} x {symbol}", "error", user_id=u_id)
                            
                            result = await asyncio.to_thread(
                                client.place_order,
                                symbol=symbol,
                                qty=qty,
                                side=side,
                                order_type="MARKET",
                                product="INTRADAY"
                            )
                            logger.info(f"Emergency exit result: {result}")
                        except Exception as exit_err:
                            logger.error(f"Emergency exit error for {pos.get('symbol')}: {exit_err}")
                    
                    # Disable automation and clear active trades
                    state.automation_enabled = False
                    state.active_auto_trades = []
                    state.hard_exit_triggered = True
                    state.record_loss()
                    state.save()
                    
                    await broadcast_log("🛑 AUTOMATION DISABLED — Max loss limit hit. All positions exited.", "error")
                    continue
                    
                # ═══════════════════════════════════════════
                # CLEANUP COMPLETED TRADES
                # ═══════════════════════════════════════════
                completed_trades = []
                for t in state.active_auto_trades:
                    # Skip cleanup if the trade was opened less than 20 seconds ago
                    if time.time() - t.get("opened_at", 0) < 20:
                        continue
                    sym = t["symbol"]
                    pos = next((p for p in positions if p.get("symbol") == sym), None)
                    # If the position exists in cache and qty is 0, the trade is closed
                    if pos is not None and abs(pos.get("qty", 0)) == 0:
                        completed_trades.append((sym, pos))
                        
                if completed_trades:
                    for sym, pos in completed_trades:
                        trade_pnl = pos.get("pl", 0)
                        if trade_pnl > 0:
                            # Profitable trade
                            state.trades_today = max(0, state.trades_today - 1)
                            state.record_trade_close("profit")  # 3 min cooldown
                            await broadcast_log(f"🎉 Trade PROFIT ₹{trade_pnl:.2f}! ⏳ Cooldown: 3 minutes before next trade.", "success", user_id=u_id)
                        elif trade_pnl < 0:
                            # Loss trade
                            state.record_trade_close("loss")  # 5 min cooldown
                            await broadcast_log(f"📉 Trade LOSS ₹{trade_pnl:.2f}. ⏳ Cooldown: 5 minutes before next trade.", "warning", user_id=u_id)
                        else:
                            # Breakeven
                            state.record_trade_close("breakeven")  # 3 min cooldown
                            await broadcast_log(f"➖ Trade BREAKEVEN. ⏳ Cooldown: 3 minutes before next trade.", "info")
                        state.remove_active_trade(sym)
                    logger.info(f"🧹 Cleaned up completed trades: {[s for s, _ in completed_trades]}")
                    
                # ═══════════════════════════════════════════
                # TRAILING SL MONITOR (10-Point Step Trailing)
                # ═══════════════════════════════════════════
                symbols = [t["symbol"] for t in state.active_auto_trades]
                if not symbols:
                    await asyncio.sleep(5)
                    continue
                    
                # Try to get quotes from WS feed first
                quotes = ws_feed.get_quotes_from_ws(symbols) if ws_feed.is_connected() else {}
                missing_symbols = [s for s in symbols if s not in quotes]
                
                if missing_symbols:
                    rest_quotes = await asyncio.to_thread(client.get_quotes, missing_symbols)
                    quotes.update(rest_quotes)
                
                for t in state.active_auto_trades:
                    sym = t["symbol"]
                    quote = quotes.get(sym, {})
                    ltp = quote.get("lp", 0)
                    
                    if ltp == 0: continue
                    
                    entry = t["entry_price"]
                    side = t.get("side", "BUY")
                    pos = next((p for p in positions if p.get("symbol") == sym), None)

                    # Strategy 3 (ORB) Target Monitoring
                    if t.get("strategy") == "Strategy 3: 5-Minute ORB":
                        target_1 = t.get("target_1")
                        target_2 = t.get("target_2")
                        trailed = t.get("trailed", False)
                        
                        if target_1 and target_2:
                            is_target_1_hit = False
                            is_target_2_hit = False
                            
                            if side == "BUY":
                                if ltp >= target_1:
                                    is_target_1_hit = True
                                if ltp >= target_2:
                                    is_target_2_hit = True
                            else: # SELL
                                if ltp <= target_1:
                                    is_target_1_hit = True
                                if ltp <= target_2:
                                    is_target_2_hit = True
                                    
                            if is_target_2_hit:
                                logger.info(f"🎯 Strategy 3 Target 2 Hit for {sym} at ₹{ltp} (Target: ₹{target_2})! Exiting.")
                                await broadcast_log(f"🎯 Strategy 3 Target 2 Hit for {sym} at ₹{ltp}! Exiting...", "success", user_id=u_id)
                                
                                # Cancel SL order
                                sl_order_id = t.get("sl_order_id")
                                if sl_order_id:
                                    try:
                                        await asyncio.to_thread(client.cancel_order, sl_order_id)
                                    except Exception as e:
                                        logger.error(f"Error cancelling SL order: {e}")
                                
                                # Exit position
                                exit_side = "SELL" if side == "BUY" else "BUY"
                                qty = t.get("qty", 65)
                                if pos:
                                    qty = abs(pos.get("qty", qty))
                                
                                product_type = "INTRADAY" if "INDEX" not in sym and "-EQ" in sym else "MARGIN"
                                exit_res = await asyncio.to_thread(
                                    client.place_order,
                                    symbol=sym,
                                    qty=qty,
                                    side=exit_side,
                                    order_type="MARKET",
                                    product=product_type,
                                    sl_points=0.0,
                                    target_points=0.0
                                )
                                if exit_res.get("success"):
                                    trade_pnl = (ltp - entry) if side == "BUY" else (entry - ltp)
                                    result_type = "profit" if trade_pnl > 0 else "loss"
                                    state.record_trade_close(result_type)
                                    await broadcast_log(f"✅ Strategy 3 exit at ₹{ltp}. ⏳ Cooldown: {3 if result_type == 'profit' else 5} minutes.", "success", user_id=u_id)
                                    state.remove_active_trade(sym)
                                else:
                                    await broadcast_log(f"⚠️ Strategy 3 exit failed: {exit_res.get('message')}", "error", user_id=u_id)
                                continue
                                
                            if is_target_1_hit and not trailed:
                                logger.info(f"🛡️ Strategy 3 Target 1 Hit for {sym} at ₹{ltp}! Trailing SL to breakeven (₹{entry}).")
                                sl_order_id = t.get("sl_order_id")
                                if sl_order_id:
                                    limit_price = entry - 1.0 if side == "BUY" else entry + 1.0
                                    limit_price = round(round(limit_price / 0.05) * 0.05, 2)
                                    mod_res = await asyncio.to_thread(
                                        client.modify_order,
                                        order_id=sl_order_id,
                                        order_type=t.get("sl_order_type", 4),
                                        stop_price=entry,
                                        limit_price=limit_price
                                    )
                                    if mod_res.get("success"):
                                        await broadcast_log(f"🛡️ Strategy 3 SL trailed to breakeven (₹{entry})", "success", user_id=u_id)
                                        state.update_trade_sl_price(sl_order_id, entry)
                                        state.mark_trade_trailed(sl_order_id)
                                    else:
                                        await broadcast_log(f"⚠️ Strategy 3 SL trail failed: {mod_res.get('message')}", "warning", user_id=u_id)
                                else:
                                    t["trailed"] = True
                                    state.save()
                        continue
                    
                    sl_pts = t["sl_points"]
                    last_step = t.get("last_trail_step", 0)
                    
                    if side == "BUY":
                        points_gained = ltp - entry
                        step = int(points_gained / 10.0)
                        
                        if step > last_step:
                            initial_sl = entry - sl_pts
                            new_sl_price = initial_sl + (step * 10.0)
                            new_sl_price = round(round(new_sl_price / 0.05) * 0.05, 2)
                            
                            # Double check that we are actually moving the SL price up
                            current_sl_price = initial_sl + (last_step * 10.0)
                            if new_sl_price > current_sl_price:
                                logger.info(f"🚀 Trailing Milestone Hit for {sym}! LTP: {ltp} | Step: {step} | Prev Step: {last_step}")
                                
                                if t.get("sl_order_id"):
                                    mod_res = await asyncio.to_thread(
                                        client.modify_order,
                                        order_id=t["sl_order_id"],
                                        order_type=t.get("sl_order_type", 4),
                                        stop_price=new_sl_price,
                                        limit_price=new_sl_price - 1.0
                                    )
                                    if mod_res.get("success"):
                                        logger.info(f"🛡️ Trailed SL to ₹{new_sl_price} for {sym}")
                                        await broadcast_log(f"🛡️ SL trailed to ₹{new_sl_price} (step {step})", "success")
                                        state.update_trade_sl_price(t["sl_order_id"], new_sl_price)
                                        state.update_trade_trail_step(t["sl_order_id"], step)
                                    else:
                                        logger.error(f"❌ Failed to trail SL to ₹{new_sl_price} for {sym}: {mod_res.get('message')}")
                                        await broadcast_log(f"⚠️ Trailing SL failed: {mod_res.get('message')}", "warning")
                                else:
                                    logger.warning(f"⚠️ No SL order ID tracked for {sym}, cannot modify on-exchange SL.")
                                    # Fallback: still update state step so we don't spam errors
                                    state.update_trade_trail_step(t.get("sl_order_id", ""), step)

                    elif side == "SELL":
                        # For SELL trades: profit when price drops
                        points_gained = entry - ltp
                        step = int(points_gained / 10.0)
                        
                        if step > last_step:
                            initial_sl = entry + sl_pts
                            new_sl_price = initial_sl - (step * 10.0)
                            new_sl_price = round(round(new_sl_price / 0.05) * 0.05, 2)
                            
                            # Double check that we are actually moving the SL price down
                            current_sl_price = initial_sl - (last_step * 10.0)
                            if new_sl_price < current_sl_price:
                                logger.info(f"🚀 [SELL] Trailing Milestone Hit for {sym}! LTP: {ltp} | Step: {step} | Prev Step: {last_step}")
                                
                                if t.get("sl_order_id"):
                                    mod_res = await asyncio.to_thread(
                                        client.modify_order,
                                        order_id=t["sl_order_id"],
                                        order_type=t.get("sl_order_type", 4),
                                        stop_price=new_sl_price,
                                        limit_price=new_sl_price + 1.0
                                    )
                                    if mod_res.get("success"):
                                        logger.info(f"🛡️ [SELL] Trailed SL to ₹{new_sl_price} for {sym}")
                                        await broadcast_log(f"🛡️ SL trailed to ₹{new_sl_price} (step {step})", "success")
                                        state.update_trade_sl_price(t["sl_order_id"], new_sl_price)
                                        state.update_trade_trail_step(t["sl_order_id"], step)
                                    else:
                                        logger.error(f"❌ [SELL] Failed to trail SL to ₹{new_sl_price} for {sym}: {mod_res.get('message')}")
                                        await broadcast_log(f"⚠️ Trailing SL failed: {mod_res.get('message')}", "warning")
                                else:
                                    logger.warning(f"⚠️ No SL order ID tracked for {sym}, cannot modify on-exchange SL.")
                                    state.update_trade_trail_step(t.get("sl_order_id", ""), step)

        except Exception as e:
            logger.error(f"Trailing monitor error: {e}")
            
        await asyncio.sleep(1)  # Monitor every 1 second for fast trailing

async def calculate_smart_sl(strike_symbol: str, entry_ltp: float, trend: str, client) -> Dict:
    """
    Calculate smart SL based on strike's candle chart.
    
    TRENDING: SL = Swing Low (lowest low of recent candles), capped at 12 pts
    RANGE-BOUND: SL = ATR × 1.5, capped at 8 pts
    
    Returns: {"sl_points": float, "target_points": float, "method": str}
    """
    state = get_user_state(client.user_id)
    MAX_SL = state.max_sl_trending  # Configurable via Settings UI
    RANGE_MAX_SL = state.max_sl_range  # Configurable via Settings UI
    
    try:
        # Fetch strike's 5-min candle history (today only = 1 day back)
        candles = await asyncio.to_thread(
            client.get_historical, strike_symbol, "5", 1
        )
        
        if not candles or len(candles) < 3:
            # Fallback: use fixed SL if no candle data
            logger.warning(f"Not enough candle data for {strike_symbol}. Using fixed SL.")
            return {"sl_points": MAX_SL, "target_points": MAX_SL * 2, "method": "fixed_fallback"}
        
        # Only use recent candles (last 10 or all available)
        recent = candles[-10:]
        
        is_trending = "BULL" in trend.upper() or "BEAR" in trend.upper()
        
        if is_trending:
            # ═══ TRENDING: SL = Swing Low ═══
            lowest_low = min(c["low"] for c in recent)
            sl_distance = round(entry_ltp - lowest_low, 2)
            
            # Ensure SL is positive and reasonable
            if sl_distance <= 0:
                sl_distance = 5.0  # Minimum 5 pts
            
            sl_points = min(sl_distance, MAX_SL)
            sl_points = max(sl_points, 3.0)  # At least 3 pts to avoid noise
            target_points = round(sl_points * 2, 2)  # 1:2 RR
            
            logger.info(f"📊 TRENDING SL: Swing Low={lowest_low}, Distance={sl_distance}, SL={sl_points}, TGT={target_points}")
            return {"sl_points": sl_points, "target_points": target_points, "method": "swing_low"}
        
        else:
            # ═══ RANGE-BOUND: SL = ATR × 1.5 ═══
            atrs = []
            for c in recent:
                atr_val = c["high"] - c["low"]
                atrs.append(atr_val)
            
            avg_atr = sum(atrs) / len(atrs) if atrs else 5.0
            sl_points = round(avg_atr * 1.5, 2)
            
            # Range-bound: tighter limits
            sl_points = min(sl_points, RANGE_MAX_SL)
            sl_points = max(sl_points, 3.0)
            target_points = round(sl_points * 1.5, 2)  # 1:1.5 RR
            
            logger.info(f"📊 RANGE SL: ATR={avg_atr:.2f}, SL={sl_points}, TGT={target_points}")
            return {"sl_points": sl_points, "target_points": target_points, "method": "atr_range"}
            
    except Exception as e:
        logger.error(f"Smart SL calculation error: {e}")
        return {"sl_points": MAX_SL, "target_points": MAX_SL * 2, "method": "error_fallback"}


async def execute_auto_trade(symbol: str, sig: Dict, analysis: Dict, client):
    """Execute an automated trade based on confirmed signal with smart SL.
    POLICY: Only BUY trades on CE/PE options. SELL trades are blocked."""
    try:
        state = get_user_state(client.user_id)
        
        # ═══════════════════════════════════════════
        # GUARD: Block if already in a trade
        # ═══════════════════════════════════════════
        if len(state.active_auto_trades) > 0:
            logger.warning(f"⛔ Trade blocked: Already have {len(state.active_auto_trades)} active trade(s).")
            await broadcast_log(f"⛔ Trade blocked: Already in an active trade.", "warning", user_id=client.user_id)
            return
        
        # ═══════════════════════════════════════════
        # POLICY: BUY ONLY — Block all SELL trades
        # ═══════════════════════════════════════════
        requested_side = sig.get("side", "BUY")
        if requested_side.upper() != "BUY":
            logger.warning(f"⛔ SELL trade blocked by policy. Signal side={requested_side}. Only BUY trades allowed.")
            await broadcast_log(f"⛔ SELL trade blocked: Only BUY trades on CE/PE allowed.", "warning", user_id=client.user_id)
            return
        
        # ═══════════════════════════════════════════
        # REGIME LOCKOUT: Block trades in flat/choppy markets
        # ═══════════════════════════════════════════
        norm_analysis = analysis if isinstance(analysis, dict) else {}
        trend_info = norm_analysis.get("trend", {})
        if isinstance(trend_info, str):
            current_trend = trend_info.upper()
        elif isinstance(trend_info, dict):
            current_trend = (trend_info.get("trend", "") or "").upper()
        else:
            current_trend = "NEUTRAL"
            
        if any(x in current_trend for x in ["NEUTRAL", "RANGE_BOUND", "RANGE", "SIDEWAYS", "CHOOPY", "CHOPPY"]):
            logger.warning(f"⛔ Auto-trade blocked: Trend regime is {current_trend} (Zero-Trading lockout active).")
            await broadcast_log(f"⛔ Auto-trade blocked: Regime is {current_trend} (Choppy/Sideways Lockout).", "warning", user_id=client.user_id)
            return
            
        sig_type = sig.get("type", "").upper()
        if "BULL" in current_trend and sig_type != "CALL":
            logger.warning(f"⛔ Auto-trade blocked: Trend is {current_trend} but signal is {sig_type} (only CALL CE allowed).")
            await broadcast_log(f"⛔ Auto-trade blocked: Trend is {current_trend} but signal is {sig_type}.", "warning", user_id=client.user_id)
            return
        if "BEAR" in current_trend and sig_type != "PUT":
            logger.warning(f"⛔ Auto-trade blocked: Trend is {current_trend} but signal is {sig_type} (only PUT PE allowed).")
            await broadcast_log(f"⛔ Auto-trade blocked: Trend is {current_trend} but signal is {sig_type}.", "warning", user_id=client.user_id)
            return
        
        # ═══════════════════════════════════════════
        # STRATEGY 2: Direct Option Trade (skip strike selection)
        # ═══════════════════════════════════════════
        if sig.get("is_direct_option"):
            strike_info = sig.get("strike_info", {})
            strike_symbol = strike_info.get("symbol")
            if not strike_symbol:
                logger.error("Direct option trade missing symbol!")
                await broadcast_log(f"❌ {sig.get('strategy', 'Strategy 2')}: Missing symbol", "error", user_id=client.user_id)
                return
            
            # Fetch fresh LTP
            fresh_quote = await asyncio.to_thread(client.get_quote, strike_symbol)
            entry_price = fresh_quote.get("lp", 0) if fresh_quote else 0
            if entry_price <= 0:
                entry_price = strike_info.get("ltp", sig.get("entry_price", 180))
            
            sl_points = sig.get("sl_points", 20.0)
            qty = sig.get("qty", 65)

            # Determine product and targets based on strategy
            is_orb = sig.get("strategy") == "Strategy 3: 5-Minute ORB"
            
            if is_orb:
                # For Strategy 3 (ORB): Use standard MARGIN for options or INTRADAY for stock equity
                if "INDEX" not in strike_symbol and "-EQ" in strike_symbol:
                    product_type = "INTRADAY"
                else:
                    product_type = "MARGIN"
                target_points = 0.0  # programmatically exit at target 2
            else:
                trend_info = analysis.get("trend", {})
                current_trend = (trend_info.get("trend", "") or "").upper()
                is_trending = "BULL" in current_trend or "BEAR" in current_trend
                
                if is_trending:
                    product_type = "CO"
                    target_points = 0.0
                else:
                    product_type = "BO"
                    target_points = 150.0

            side = sig.get("side", "BUY")
            strategy_name = sig.get("strategy", "Strategy 2: 9:26 - 180 Buy")

            logger.info(f"🚀 {strategy_name} TRADE: {sig['type']} {side} {strike_symbol} @ ₹{entry_price} | SL: {sl_points}pts | TGT: {target_points}pts | Product: {product_type}")
            await broadcast_log(                f"🚀 {strategy_name}: {sig['type']} {side} {strike_symbol} @ ₹{entry_price} | SL: {sl_points}pts | Product: {product_type}",
                "success"
            )
            
            result = await asyncio.to_thread(
                client.place_order,
                symbol=strike_symbol,
                qty=qty,
                side=side,
                order_type="MARKET",
                product=product_type,
                sl_points=sl_points,
                target_points=target_points
            )
            
            if result.get("success"):
                state.record_trade()
                state.add_active_trade(
                    symbol=strike_symbol,
                    entry_price=entry_price,
                    sl_points=sl_points,
                    side=side,
                    sl_order_id=result.get("sl_order_id", ""),
                    tgt_order_id=result.get("tgt_order_id", ""),
                    strategy=strategy_name if is_orb else None,
                    target_1=sig.get("target_1") if is_orb else None,
                    target_2=sig.get("target_2") if is_orb else None,
                    sl_order_type=result.get("sl_order_type", 4)
                )
                log_trade({
                    "symbol": strike_symbol, "side": side, "qty": qty,
                    "price": entry_price, "signal_type": f"{strategy_name}_{sig['type']}",
                    "status": "PLACED", "sl": sl_points, "target": target_points,
                    "sl_method": "orb_checklist" if is_orb else "strategy_926_fixed"
                })
                await broadcast_log(                    f"✅ {strategy_name} Order placed: {strike_symbol} @ ₹{entry_price} | {result.get('message', '')}",
                    "success"
                )
                logger.info(f"✅ {strategy_name} trade executed: {result}")
            else:
                logger.error(f"❌ {strategy_name} trade failed: {result.get('message', 'Unknown')}")
                await broadcast_log(f"❌ {strategy_name} failed: {result.get('message', '')}", "error", user_id=client.user_id)
            return  # Exit — Strategy 2 is done
        
        # ═══════════════════════════════════════════
        # STRATEGY 1: Standard OB + FVG Trade Flow
        # ═══════════════════════════════════════════
        spot = analysis.get("spot", 0)
        expiry = analysis.get("expiry")
        
        if not expiry:
            logger.warning(f"No expiry found for {symbol}. Skipping auto-trade.")
            await broadcast_log(f"⚠️ No expiry found for auto-trade", "warning", user_id=client.user_id)
            return
        
        # ═══════════════════════════════════════════
        # SPOT VALIDATION — Don't trade stale signals
        # ═══════════════════════════════════════════
        entry_zone_top = sig.get("entry_zone_top", sig.get("entry_price", spot))
        entry_zone_bottom = sig.get("entry_zone_bottom", sig.get("entry_price", spot) - 50)
        
        if sig.get("type") == "CALL":
            # For CALL: spot should not be far below the entry zone
            if spot < entry_zone_bottom - 20:
                logger.info(f"⏭️ SPOT VALIDATION: Spot {spot} dropped below entry zone {entry_zone_bottom}. Signal stale.")
                await broadcast_log(f"⏭️ Signal stale: Spot ₹{spot:.0f} below entry zone ₹{entry_zone_bottom:.0f}", "warning", user_id=client.user_id)
                return
        elif sig.get("type") == "PUT":
            # For PUT: spot should not be far above the entry zone
            if spot > entry_zone_top + 20:
                logger.info(f"⏭️ SPOT VALIDATION: Spot {spot} rose above entry zone {entry_zone_top}. Signal stale.")
                await broadcast_log(f"⏭️ Signal stale: Spot ₹{spot:.0f} above entry zone ₹{entry_zone_top:.0f}", "warning", user_id=client.user_id)
                return
        
        # ═══════════════════════════════════════════
        # SELECT STRIKE
        # ═══════════════════════════════════════════
        option_chain = analysis.get("option_chain")
        if not option_chain:
            try:
                option_chain = await asyncio.to_thread(
                    client.get_option_chain_strikes, spot, expiry["code"], 5
                )
            except Exception as e:
                logger.error(f"Option chain fetch failed: {e}")
                await broadcast_log(f"❌ Option chain error: {str(e)[:80]}", "error", user_id=client.user_id)
                return
        
        dte = expiry.get("dte", 5)
        recommendations = get_strike_recommendations(option_chain, sig["type"], spot, dte)
        
        if not recommendations:
            logger.warning(f"No suitable strikes found for {sig['type']} at spot {spot}")
            await broadcast_log(f"⚠️ No strikes found for {sig['type']}", "warning", user_id=client.user_id)
            return
        
        best_strike = recommendations[0]
        strike_symbol = best_strike.get("symbol")
        
        if not strike_symbol:
            logger.warning(f"Invalid strike data: {best_strike}")
            return
        
        # ═══════════════════════════════════════════
        # FETCH FRESH LIVE LTP (with candle fallback)
        # ═══════════════════════════════════════════
        entry_price = 0
        
        # Try 1: Live quote
        fresh_quote = await asyncio.to_thread(client.get_quote, strike_symbol)
        if fresh_quote and fresh_quote.get("lp", 0) > 0:
            entry_price = fresh_quote["lp"]
            logger.info(f"📊 Fresh LTP for {strike_symbol}: ₹{entry_price}")
        
        # Try 2: Cached LTP from option chain
        if entry_price <= 0:
            entry_price = best_strike.get("ltp", 0)
            if entry_price > 0:
                logger.info(f"📊 Cached LTP for {strike_symbol}: ₹{entry_price}")
        
        # Try 3: Historical candle fallback (latest 1-min close)
        if entry_price <= 0:
            try:
                candle_data = await asyncio.to_thread(
                    client.get_historical, strike_symbol, "1", 1
                )
                if candle_data and len(candle_data) > 0:
                    entry_price = candle_data[-1].get("close", 0)
                    if entry_price > 0:
                        logger.info(f"📊 Candle fallback LTP for {strike_symbol}: ₹{entry_price}")
            except Exception as e:
                logger.warning(f"Candle fallback failed for {strike_symbol}: {e}")
        
        # Try 4: Estimate ATM premium from spot-strike distance
        # For NIFTY ATM options with 3-7 DTE, premium ≈ 150-250
        if entry_price <= 0:
            try:
                strike_price = best_strike.get("strike", 0)
                if strike_price > 0 and spot > 0:
                    distance = abs(spot - strike_price)
                    # Rough Black-Scholes estimate for NIFTY options
                    # ATM: ~200, ITM adds intrinsic, OTM reduces
                    intrinsic = max(0, spot - strike_price) if "CE" in strike_symbol else max(0, strike_price - spot)
                    time_value = max(80, 200 - distance * 0.5)  # Decay with distance from ATM
                    entry_price = round(intrinsic + time_value, 2)
                    logger.info(f"📊 ESTIMATED premium for {strike_symbol}: ₹{entry_price} (spot={spot}, strike={strike_price}, intrinsic={intrinsic})")
                    await broadcast_log(f"📊 Using estimated premium ₹{entry_price} (quotes API throttled)", "warning", user_id=client.user_id)
            except Exception as e:
                logger.warning(f"Premium estimation failed: {e}")
        
        if entry_price <= 0:
            logger.warning(f"Invalid entry price for {strike_symbol}")
            await broadcast_log(f"⚠️ Cannot get price for {strike_symbol}. Retrying next cycle.", "warning", user_id=client.user_id)
            return
        
        # ═══════════════════════════════════════════
        # SMART SL CALCULATION (Chart-based)
        # ═══════════════════════════════════════════
        trend_info = analysis.get("trend", {})
        current_trend = (trend_info.get("trend", "") or "").upper()
        
        sl_data = await calculate_smart_sl(strike_symbol, entry_price, current_trend, client)
        sl_points = sl_data["sl_points"]
        sl_method = sl_data["method"]
        
        # Determine market regime for order type
        is_trending = "BULL" in current_trend or "BEAR" in current_trend
        if is_trending:
            product_type = "CO"
            target_points = 0.0
        else:
            product_type = "BO"
            target_points = 150.0

        lot_size = get_lot_size(strike_symbol)
        qty = state.trade_lots * lot_size
        
        logger.info(f"🚀 AUTO-TRADE: {sig['type']} {strike_symbol} @ ₹{entry_price} | SL: {sl_points} ({sl_method}) | TGT: {target_points} | Regime: {'TRENDING (CO)' if is_trending else 'RANGE (BO)'}")
        await broadcast_log(            f"🚀 AUTO-TRADE: {sig['type']} {strike_symbol} @ ₹{entry_price} | SL: {sl_points}pts | TGT: {target_points}pts | Regime: {'TRENDING' if is_trending else 'RANGE'}",
            "success"
        )
        
        # ═══════════════════════════════════════════
        # PLACE ORDER
        # ═══════════════════════════════════════════
        result = await asyncio.to_thread(
            client.place_order,
            symbol=strike_symbol,
            qty=qty,
            side="BUY",
            order_type="MARKET",
            product=product_type,
            limit_price=entry_price,  # Pass pre-fetched price to avoid double-quote
            sl_points=sl_points,
            target_points=target_points
        )
        
        if result.get("success"):
            state.record_trade()
            state.add_active_trade(
                symbol=strike_symbol,
                entry_price=entry_price,
                sl_points=sl_points,
                side="BUY",
                sl_order_id=result.get("sl_order_id", ""),
                tgt_order_id=result.get("tgt_order_id", ""),
                sl_order_type=result.get("sl_order_type", 4)
            )
            
            log_trade({
                "symbol": strike_symbol,
                "side": "BUY",
                "qty": qty,
                "price": entry_price,
                "signal_type": f"AUTO_{sig['type']}",
                "status": "PLACED",
                "sl": sl_points,
                "target": target_points,
                "sl_method": sl_method
            })
            log_signal([sig], spot, f"🟢 AUTO EXECUTED ({sig['type']})", best_strike)
            
            await broadcast_log(                f"✅ Order placed: {strike_symbol} @ ₹{entry_price} | SL: {sl_points}pts | TGT: {target_points}pts | {result.get('message', '')}",
                "success"
            )
            logger.info(f"✅ Auto-trade executed: {result}")
        else:
            logger.error(f"❌ Auto-trade failed: {result.get('message', 'Unknown error')}")
            await broadcast_log(f"❌ Auto-trade failed: {result.get('message', '')}", "error", user_id=client.user_id)
            
    except Exception as e:
        logger.error(f"Auto-trade execution error: {e}")
        await broadcast_log(f"❌ Auto-trade error: {str(e)[:100]}", "error", user_id=client.user_id)


async def automation_loop():
    """Continuously monitor symbols and execute AI-confirmed signals."""
    logger.info("🤖 Automation Loop Started.")
    while True:
        try:
            # EOD Report Check & Sleep if market is closed
            if not _is_market_open():
                for u_id in list(USER_CONTEXTS.keys()):
                    state = get_user_state(u_id)
                    state.check_daily_reset()
                    state.check_and_send_eod_report()
                await asyncio.sleep(30)
                continue

            for u_id, client in USER_CONTEXTS.items():
                try:
                    if not await asyncio.to_thread(client.is_authenticated):
                        continue
                except:
                    continue
                    
                state = get_user_state(u_id)
                trade_placed = False
                
                # Daily reset check per user
                if state.check_daily_reset():
                    await broadcast_log(f"🔄 New trading day! Counters reset for User {u_id}.", "success", user_id=client.user_id)

                if not state.automation_enabled:
                    continue

                # Enforce strictly one active trade (both local state and live Fyers positions)
                cache = get_user_cache(u_id)
                positions = cache.get("active_positions", [])
                open_positions = [p for p in positions if p.get("qty", 0) != 0]
                if len(state.active_auto_trades) > 0 or len(open_positions) > 0:
                    continue

                # Strategy 2: 9:26 - 9:35 Breakout (Independent of Strategy 1)
                try:
                    sig_926 = await evaluate_926_strategy(client, state)
                    if sig_926:
                        logger.info(f"⚡ Strategy 2 Signal detected for User {u_id}: {sig_926['type']}")
                        can_trade, reason = state.can_trade("STRATEGY_926")
                        if can_trade:
                            entry = sig_926.get('entry_price', 180)
                            await broadcast_log(f"🚀 Strategy 2 (User {u_id}): {sig_926['type']} triggered at ₹{entry}!", "success", user_id=client.user_id)
                            analysis_nifty = await get_analysis("NSE:NIFTY50-INDEX", client=client)
                            trend_dict = analysis_nifty.get("trend", {}) if analysis_nifty else {"trend": "NEUTRAL"}
                            await execute_auto_trade(sig_926['symbol'], sig_926, {"trend": trend_dict}, client)
                            trade_placed = True
                            continue  # ← CRITICAL: Skip all other strategies after placing a trade
                        else:
                            logger.info(f"⏭️ Strategy 2 blocked for User {u_id}: {reason}")
                except Exception as e:
                    logger.error(f"Error in Strategy 2 loop for User {u_id}: {e}")

                # Strategy 3: 5-Minute ORB (Opening Range Breakout)
                try:
                    if not trade_placed and "Strategy 3: 5-Minute ORB" in state.active_strategies and not getattr(state, "strat_orb_triggered", False):
                        now = datetime.now(IST)
                        current_time_str = now.strftime("%H:%M:%S")
                        if "09:25:00" <= current_time_str <= "09:30:00":
                            for symbol in state.active_symbols:
                                if len(state.active_auto_trades) > 0 or trade_placed:
                                    break
                                
                                candles_5m = await asyncio.to_thread(client.get_historical, symbol, "5", days_back=4)
                                candles_daily = await asyncio.to_thread(client.get_historical, symbol, "D", days_back=10)
                                if candles_5m and candles_daily:
                                    sig_orb = await evaluate_orb_strategy(client, state, symbol, candles_5m, candles_daily, vix=15.0)
                                    if sig_orb:
                                        logger.info(f"⚡ Strategy 3 Signal detected for User {u_id} on {symbol}: {sig_orb['type']}")
                                        can_trade, reason = state.can_trade("STRATEGY_ORB")
                                        if can_trade:
                                            entry = sig_orb.get('entry_price', 0)
                                            await broadcast_log(f"🚀 Strategy 3 (User {u_id}) ORB Triggered on {symbol} ({sig_orb['type']}) at ₹{entry}!", "success", user_id=client.user_id)
                                            await execute_auto_trade(symbol, sig_orb, {"trend": "NEUTRAL"}, client)
                                            state.strat_orb_triggered = True
                                            state.save()
                                            trade_placed = True
                                            break
                                        else:
                                            logger.info(f"⏭️ Strategy 3 blocked for User {u_id}: {reason}")
                except Exception as e:
                    logger.error(f"Error in Strategy 3 loop for User {u_id}: {e}")

                for symbol in state.active_symbols:
                    if trade_placed:
                        break
                    # 1. Get Analysis
                    analysis = await get_analysis(symbol, client=client)
                    if not analysis or not analysis.get("signals"):
                        continue
                    
                    logger.info(f"🔍 LOOP [{symbol} - User {u_id}]: Found {len(analysis.get('signals', []))} raw signals. Active Strats: {state.active_strategies}")

                    # 2. Check for actionable signals
                    for sig in analysis["signals"]:
                        if trade_placed:
                            break
                        if sig.get("type") not in ("CALL", "PUT"):
                            continue
                        
                        tech_conf = sig.get("confidence", 0)
                        if tech_conf < 50:
                            continue
                        
                        trend_info = analysis.get("trend", {})
                        current_trend = (trend_info.get("trend", "") or "").upper()
                        trend_strength = trend_info.get("strength", 0)
                        signal_type = sig.get("type")
                        
                        if signal_type == "CALL" and "BEAR" in current_trend:
                            continue
                        elif signal_type == "PUT" and "BULL" in current_trend:
                            continue
                        
                        if "NEUTRAL" in current_trend or "SIDEWAYS" in current_trend:
                            if tech_conf < 70:
                                continue
                        
                        if state.profit_target_met:
                            if tech_conf < 85:
                                continue
                        
                        can_trade, reason = state.can_trade(symbol.replace(':','_'))
                        if not can_trade:
                            # Broadcast cooldown status (but only once per 30s to avoid spam)
                            if "Cooldown" in reason:
                                last_log = getattr(state, '_last_cooldown_log', 0)
                                now_ts = datetime.now(IST).timestamp()
                                if (now_ts - last_log) > 30:
                                    state._last_cooldown_log = now_ts
                                    await broadcast_log(f"{reason} | Signal: {sig['type']} {tech_conf}%", "info", user_id=client.user_id)
                            continue

                        if tech_conf >= 75:
                            logger.info(f"🚀 TIER 1 AUTO-TRADE (User {u_id}): {symbol} {sig['type']} | Tech: {tech_conf}%")
                            await broadcast_log(f"🚀 HIGH CONFIDENCE ({tech_conf}%) — Auto-executing {sig['type']} trade for User {u_id}!", "success", user_id=client.user_id)
                            await execute_auto_trade(symbol, sig, analysis, client)
                            trade_placed = True
                            break
                            
                        elif tech_conf >= 50:
                            ai_conf = sig.get("ai_confidence", 0)
                            ai_status = sig.get("ai_status", "unknown")
                            ai_rationale = sig.get("ai_rationale", "")
                            
                            if ai_status == "error":
                                continue
                            
                            ai_threshold = 70
                            if ai_conf >= ai_threshold:
                                logger.info(f"🚀 AI APPROVED (User {u_id}): {sig['type']} | AI: {ai_conf}%")
                                await broadcast_log(f"🧠 AI APPROVED ({ai_conf}%): {sig['type']} — {ai_rationale[:60]} (User {u_id})", "success", user_id=client.user_id)
                                await execute_auto_trade(symbol, sig, analysis, client)
                                trade_placed = True
                                break
                            else:
                                logger.info(f"⏭️ AI REJECTED (User {u_id}): {sig['type']} | AI: {ai_conf}%")
        except Exception as e:
            logger.error(f"Automation loop error: {e}")
        
        await asyncio.sleep(5)


@app.get("/api/logs")
async def get_logs(request: Request, limit: int = 100):
    """Fetch the latest system logs for the authenticated user (and global logs)."""
    try:
        user_id = request.cookies.get("user_id")
        if not user_id:
            raise HTTPException(status_code=401, detail="Not authenticated")
        logs = Database.get_user_logs(user_id=int(user_id), limit=limit)
        return {"status": "success", "logs": logs}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error fetching logs: {str(e)}")

# Startup logic moved to lifespan() context manager at top of file

if __name__ == "__main__":
    import uvicorn
    import os
    port = int(os.environ.get("PORT", 8000))
    print(f"🚀 Starting NIFTY Trading Dashboard on http://localhost:{port}")
    uvicorn.run(app, host="0.0.0.0", port=port)

