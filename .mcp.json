{
  "mcpServers": {
    "ruflo": {
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "oh-my-pi": {
      "command": "/Users/sritejpalika/.local/bin/omp",
      "args": ["acp"],
      "autoStart": true
    },
    "graphify": {
      "command": "/Users/sritejpalika/.local/share/uv/tools/graphifyy/bin/python",
      "args": [
        "-m",
        "graphify.serve",
        "/Users/sritejpalika/Downloads/Sritej Trading/v5/trading-app/graphify-out/graph.json"
      ],
      "autoStart": true
    }
  }
}